# Always revalidate the SPA entry HTML so a new deploy shows up immediately,
# without users having to hard-refresh or clear their cache.
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate

# Build assets have content-hashed filenames, so they can be cached forever.
/_expo/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
